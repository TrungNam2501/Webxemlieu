# Server
PORT=8080
GIN_MODE=debug
# Đường dẫn tới thư mục build của frontend (mặc định ../frontend/dist)
FRONTEND_DIST=../frontend/dist

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=kverp
DB_SSLMODE=disable

# CORS – danh sách origin cho phép, ngăn cách bằng dấu phẩy.
# Trong dev nên thêm origin của vite (mặc định http://localhost:5173).
CORS_ALLOWED_ORIGINS=http://localhost:5173
