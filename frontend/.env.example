# Origin của API backend dùng cho axios. Để trống/không khai báo để dùng đường
# dẫn tương đối "/api" (qua vite proxy trong dev hoặc cùng origin trong prod).
# VITE_API_BASE_URL=http://localhost:8080/api

# Đổi target proxy của vite trong môi trường dev (mặc định http://localhost:8080).
# VITE_API_PROXY_TARGET=http://localhost:8080
